# Model Configuration
# Specify your preferred AI model using the format: provider/model-name
# Examples:
#   openai/gpt-4o-mini
#   anthropic/claude-sonnet-4-5-20250929
#   google/gemini-2.5-pro
#   groq/llama-3.3-70b-versatile
#   nvidia/meta/llama-3.3-70b-instruct
#   kimi-for-coding/k2p5
MODEL=google/gemini-2.5-pro

# API Keys (only needed for your chosen provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
KIMI_API_KEY=

# Server auth (optional — when set, all API routes require Bearer token)
# COWORKER_API_TOKEN=

# YOLO mode (optional — auto-approve all tool calls without asking)
# ⚠️  Security warning: enables shell commands, file edits, and MCP tools without confirmation
# COWORKER_YOLO=true

# CORS origins (optional — comma-separated list of extra allowed origins)
# By default only localhost/127.0.0.1 origins are allowed
# CORS_ORIGIN=https://my-app.example.com

# Data path (optional — all data stored under this directory)
# DATA_PATH=./data

# Google (gog CLI) configuration
# GOG_KEYRING_PASSWORD=            # Encrypts OAuth tokens at rest (required for VPS)
# GOG_GOOGLE_CLIENT_ID=            # Google OAuth client ID (enables Google account connection)
# GOG_GOOGLE_CLIENT_SECRET=        # Google OAuth client secret

# Voice Input (Deepgram) - Optional, for speech-to-text in chat
# Get your API key at: https://console.deepgram.com
# VITE_DEEPGRAM_API_KEY=           # Frontend voice transcription (12+ hours free tier)

# AWS Configuration (optional — enables S3 uploads, DynamoDB knowledge graph, SQS tasks)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=coworker-uploads
# AWS_DYNAMODB_TABLE=coworker-knowledge-graph
# AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/coworker-tasks
